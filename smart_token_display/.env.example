# Single source of truth for both the ESP-IDF firmware build and release.py.
# Copy to .env and fill in. .env is gitignored (never commit real secrets).
#
# Firmware build (CMakeLists.txt) injects SUPABASE_URL / SUPABASE_KEY as
# compile definitions, so the C code reads them via SUPABASE_URL / SUPABASE_ANON_KEY.
# release.py reads the same file for uploads + publishing.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Used ONLY by release.py to upload firmware to Storage (bypasses bucket RLS).
# Keep this out of the firmware build / device. If unset, release.py falls back
# to SUPABASE_KEY (which may be blocked by Storage RLS).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional (release.py only) — defaults shown:
# STORAGE_BUCKET=firmware
# TABLE_NAME=system_control
# TABLE_ROW_ID=1
# RELEASE_BIN=build/your_app.bin

# ESP-NOW gateway ("announcer" / 7th ESP) STA MAC. Each scan is unicast here in
# addition to Supabase. Format AA:BB:CC:DD:EE:FF. Placeholder below — replace
# with the real gateway MAC (run the gateway once; it prints its STA MAC). If
# left unset, the firmware broadcasts to FF:FF:FF:FF:FF:FF instead.
# The gateway + all senders must share the same fixed Wi-Fi channel
# (ESPNOW_CHANNEL in main/inc/espnow.h, default 1) == the shop router's channel.
GATEWAY_MAC=DE:AD:BE:EF:00:07
